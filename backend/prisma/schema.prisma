// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Teacher {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String         @unique
  passwordHash  String
  createdAt     DateTime       @default(now())
  subjects      Subject[]
  tests         Test[]
  refreshTokens RefreshToken[]
}

model Student {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String         @unique
  passwordHash  String
  createdAt     DateTime       @default(now())
  enrollments   Enrollment[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  tokenHash  String    @unique
  sessionId  String?   @unique
  userAgent  String?
  ipAddress  String?
  lastUsedAt DateTime?
  userType   UserType
  teacherId  String?   @db.ObjectId
  studentId  String?   @db.ObjectId
  teacher    Teacher?  @relation(fields: [teacherId], references: [id])
  student    Student?  @relation(fields: [studentId], references: [id])
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
}

enum UserType {
  TEACHER
  STUDENT
}

model Subject {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  teacherId   String    @db.ObjectId
  teacher     Teacher   @relation(fields: [teacherId], references: [id])
  name        String
  description String?
  createdAt   DateTime  @default(now())
  modules     Module[]
}

model Module {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  subjectId     String         @db.ObjectId
  subject       Subject        @relation(fields: [subjectId], references: [id])
  name          String
  createdAt     DateTime       @default(now())
  questionBanks QuestionBank[]
}

model QuestionBank {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  moduleId    String       @db.ObjectId
  module      Module       @relation(fields: [moduleId], references: [id])
  name        String
  type        String       @default("easy")
  createdAt   DateTime     @default(now())
  questions   Question[]
  testQbRules TestQbRule[]
}

enum QuestionType {
  MCQ
  TEXT
}

model Question {
  id               String               @id @default(auto()) @map("_id") @db.ObjectId
  qbId             String               @db.ObjectId
  questionBank     QuestionBank         @relation(fields: [qbId], references: [id])
  type             QuestionType
  questionText     String
  imageUrl         String?
  createdAt        DateTime             @default(now())
  deletedAt        DateTime?
  mcqOptions       McqOption[]
  acceptedAnswers  TextAcceptedAnswer[]
  attemptQuestions AttemptQuestion[]
}

model McqOption {
  id                     String                @id @default(auto()) @map("_id") @db.ObjectId
  questionId             String                @db.ObjectId
  question               Question              @relation(fields: [questionId], references: [id])
  optionText             String
  imageUrl               String?
  scorePercent           Int
  attemptAnswerSelections AttemptAnswerOption[]
}

model TextAcceptedAnswer {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  questionId String   @db.ObjectId
  question   Question @relation(fields: [questionId], references: [id])
  answerText String
}

model Test {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  teacherId       String       @db.ObjectId
  teacher         Teacher      @relation(fields: [teacherId], references: [id])
  title           String
  enrollmentKey   String?
  startTime       DateTime
  endTime         DateTime
  durationMinutes Int
  totalMarks      Int
  isLocked        Boolean      @default(false)
  createdAt       DateTime     @default(now())
  testQbRules     TestQbRule[]
  enrollments     Enrollment[]

  // Proctoring configuration settings
  useFullscreen   Boolean      @default(false)
  logActivities   Boolean      @default(false)
  preventCopyPaste Boolean     @default(false)

  // Advanced configurations
  saveAttempts     Boolean      @default(true)
  infiniteTries    Boolean      @default(false)
  resultsReveal    Boolean      @default(true)
}

model TestQbRule {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  testId           String       @db.ObjectId
  test             Test         @relation(fields: [testId], references: [id])
  qbId             String       @db.ObjectId
  questionBank     QuestionBank @relation(fields: [qbId], references: [id])
  questionsToPick  Int
  marksPerQuestion Int
  randomQuestions  Boolean      @default(true)
  randomOrder      Boolean      @default(true)
  uniqueQuestions  Boolean      @default(false)
  shuffleOptions   Boolean      @default(false)
}

model Enrollment {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  studentId  String    @db.ObjectId
  student    Student   @relation(fields: [studentId], references: [id])
  testId     String    @db.ObjectId
  test       Test      @relation(fields: [testId], references: [id])
  enrolledAt DateTime  @default(now())
  attempts   Attempt[]

  @@unique([studentId, testId])
}

model Attempt {
  id           String            @id @default(auto()) @map("_id") @db.ObjectId
  enrollmentId String            @db.ObjectId
  enrollment   Enrollment        @relation(fields: [enrollmentId], references: [id])
  startedAt    DateTime          @default(now())
  submittedAt  DateTime?
  isSubmitted  Boolean           @default(false)
  score        Int?
  isBlocked    Boolean           @default(false)
  questions    AttemptQuestion[]

  // Embedded activity logs
  activities   AttemptActivity[]
}

model AttemptQuestion {
  id         String         @id @default(auto()) @map("_id") @db.ObjectId
  attemptId  String         @db.ObjectId
  attempt    Attempt        @relation(fields: [attemptId], references: [id])
  questionId String         @db.ObjectId
  question   Question       @relation(fields: [questionId], references: [id])
  answer     AttemptAnswer?
}

model AttemptAnswer {
  id                String                @id @default(auto()) @map("_id") @db.ObjectId
  attemptQuestionId String                @unique @db.ObjectId
  attemptQuestion   AttemptQuestion       @relation(fields: [attemptQuestionId], references: [id])
  textAnswer        String?
  marksAwarded      Int?
  selectedOptions   AttemptAnswerOption[]
}

model AttemptAnswerOption {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  attemptAnswerId String        @db.ObjectId
  attemptAnswer   AttemptAnswer @relation(fields: [attemptAnswerId], references: [id])
  mcqOptionId     String        @db.ObjectId
  mcqOption       McqOption     @relation(fields: [mcqOptionId], references: [id])
}

type AttemptActivity {
  type      String
  message   String
  timestamp DateTime
}
