// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Teacher {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  passwordHash  String
  createdAt     DateTime       @default(now())
  subjects      Subject[]
  tests         Test[]
  refreshTokens RefreshToken[]
}

model Student {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  passwordHash  String
  createdAt     DateTime       @default(now())
  enrollments   Enrollment[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id         String    @id @default(uuid())
  tokenHash  String    @unique
  userType   UserType
  teacherId  String?
  studentId  String?
  teacher    Teacher?  @relation(fields: [teacherId], references: [id])
  student    Student?  @relation(fields: [studentId], references: [id])
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
}

enum UserType {
  TEACHER
  STUDENT
}

model Subject {
  id          String    @id @default(uuid())
  teacherId   String
  teacher     Teacher   @relation(fields: [teacherId], references: [id])
  name        String
  description String?
  createdAt   DateTime  @default(now())
  modules     Module[]
}

model Module {
  id            String         @id @default(uuid())
  subjectId     String
  subject       Subject        @relation(fields: [subjectId], references: [id])
  name          String
  createdAt     DateTime       @default(now())
  questionBanks QuestionBank[]
}

model QuestionBank {
  id          String       @id @default(uuid())
  moduleId    String
  module      Module       @relation(fields: [moduleId], references: [id])
  name        String
  createdAt   DateTime     @default(now())
  questions   Question[]
  testQbRules TestQbRule[]
}

enum QuestionType {
  MCQ
  TEXT
}

model Question {
  id               String               @id @default(uuid())
  qbId             String
  questionBank     QuestionBank         @relation(fields: [qbId], references: [id])
  type             QuestionType
  questionText     String
  createdAt        DateTime             @default(now())
  deletedAt        DateTime?
  mcqOptions       McqOption[]
  acceptedAnswers  TextAcceptedAnswer[]
  attemptQuestions AttemptQuestion[]
}

model McqOption {
  id                     String                @id @default(uuid())
  questionId             String
  question               Question              @relation(fields: [questionId], references: [id])
  optionText             String
  scorePercent           Int
  attemptAnswerSelections AttemptAnswerOption[]
}

model TextAcceptedAnswer {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  answerText String
}

model Test {
  id              String       @id @default(uuid())
  teacherId       String
  teacher         Teacher      @relation(fields: [teacherId], references: [id])
  title           String
  enrollmentKey   String
  startTime       DateTime
  endTime         DateTime
  durationMinutes Int
  totalMarks      Int
  isLocked        Boolean      @default(false)
  createdAt       DateTime     @default(now())
  testQbRules     TestQbRule[]
  enrollments     Enrollment[]
}

model TestQbRule {
  id               String       @id @default(uuid())
  testId           String
  test             Test         @relation(fields: [testId], references: [id])
  qbId             String
  questionBank     QuestionBank @relation(fields: [qbId], references: [id])
  questionsToPick  Int
  marksPerQuestion Int
}

model Enrollment {
  id         String    @id @default(uuid())
  studentId  String
  student    Student   @relation(fields: [studentId], references: [id])
  testId     String
  test       Test      @relation(fields: [testId], references: [id])
  enrolledAt DateTime  @default(now())
  attempt    Attempt?

  @@unique([studentId, testId])
}

model Attempt {
  id           String            @id @default(uuid())
  enrollmentId String            @unique
  enrollment   Enrollment        @relation(fields: [enrollmentId], references: [id])
  startedAt    DateTime          @default(now())
  submittedAt  DateTime?
  isSubmitted  Boolean           @default(false)
  score        Int?
  questions    AttemptQuestion[]
}

model AttemptQuestion {
  id         String         @id @default(uuid())
  attemptId  String
  attempt    Attempt        @relation(fields: [attemptId], references: [id])
  questionId String
  question   Question       @relation(fields: [questionId], references: [id])
  answer     AttemptAnswer?
}

model AttemptAnswer {
  id                String                @id @default(uuid())
  attemptQuestionId String                @unique
  attemptQuestion   AttemptQuestion       @relation(fields: [attemptQuestionId], references: [id])
  textAnswer        String?
  marksAwarded      Int?
  selectedOptions   AttemptAnswerOption[]
}

model AttemptAnswerOption {
  id              String        @id @default(uuid())
  attemptAnswerId String
  attemptAnswer   AttemptAnswer @relation(fields: [attemptAnswerId], references: [id])
  mcqOptionId     String
  mcqOption       McqOption     @relation(fields: [mcqOptionId], references: [id])
}
